{{~ ## C# Struct Scriban Template ~}}
{{~ ## Generuje C# struct s usingy, atributy, properties a metodami ~}}

{{~ ## Usingy ~}}
{{- for using in usings -}}
using {{ using }};
{{- end }}
{{- if usings.size > 0 }}

{{- end }}
{{~ ## Atributy ~}}
{{- for attribute in attributes -}}
{{ attribute }}
{{- end }}
{{~ ## Deklarace structu ~}}
{{ access_modifier }}{{ if is_readonly }} readonly{{ end }}{{ if is_record }} record{{ end }} struct {{ name }}{{ type_params }}{{ constraints }}
{
{{~ ## Properties ~}}
{{- for property in properties -}}
    {{ property }}
{{- end }}
{{- if properties.size > 0 && methods.size > 0 }}

{{- end }}
{{~ ## Metody ~}}
{{- for method in methods -}}
    {{ method }}
{{- end }}
}
